%YAML 1.2
---
# See https://www.sublimetext.com/docs/syntax.html
# https://manpages.debian.org/unstable/debhelper/debhelper.7.en.html
name: compat (Debian)
file_extensions:
  - compat
first_line_match: '^\d+$'
scope: source.debian.compat

contexts:
  main:
    - include: debian-common.sublime-syntax#comments
    - include: body

  body:
    - match: ^\d+$
      scope: constant.numeric.integer.debian meta.number.version.debian.compat
