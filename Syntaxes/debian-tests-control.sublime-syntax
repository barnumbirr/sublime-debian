%YAML 1.2
---
# See https://www.sublimetext.com/docs/syntax.html
# https://salsa.debian.org/ci-team/autopkgtest/raw/master/doc/README.package-tests.rst
name: tests/control (Debian)
file_extensions: []
first_line_match: '^(?:Tests|Test-Command):'
scope: source.debian.tests.control

contexts:
  prototype:
    - include: debian-common.sublime-syntax#comments

  main:
    - include: fields

  fields:
    # Tests field — test script names
    - match: ^(Tests)(:)
      captures:
        1: meta.mapping.key.debian keyword.control.debian.tests.control
        2: meta.mapping.key.debian punctuation.separator.mapping.key-value.debian.tests.control
      push:
        - meta_scope: meta.mapping.debian.tests.control
        - meta_content_scope: meta.mapping.value.debian.tests.control
        - match: ^(?=\S)
          pop: true
        - match: '[\w][\w./-]+'
          scope: entity.name.function.debian.tests.control
        - match: ','
          scope: punctuation.separator.sequence.debian.tests.control
    # Test-Command field — shell command
    - match: ^(Test-Command)(:)
      captures:
        1: meta.mapping.key.debian keyword.control.debian.tests.control
        2: meta.mapping.key.debian punctuation.separator.mapping.key-value.debian.tests.control
      push:
        - meta_scope: meta.mapping.debian.tests.control
        - meta_content_scope: meta.mapping.value.debian.tests.control
        - match: ^(?=\S)
          pop: true
        - match: /\S+
          scope: string.unquoted.path.debian.tests.control
    # Restrictions field — known restriction constants
    - match: ^(Restrictions)(:)
      captures:
        1: meta.mapping.key.debian keyword.control.debian.tests.control
        2: meta.mapping.key.debian punctuation.separator.mapping.key-value.debian.tests.control
      push:
        - meta_scope: meta.mapping.debian.tests.control
        - meta_content_scope: meta.mapping.value.debian.tests.control
        - match: ^(?=\S)
          pop: true
        - include: debian-common.sublime-syntax#restrictions
        - match: ','
          scope: punctuation.separator.sequence.debian.tests.control
    # Features field — known feature constants
    - match: ^(Features)(:)
      captures:
        1: meta.mapping.key.debian keyword.control.debian.tests.control
        2: meta.mapping.key.debian punctuation.separator.mapping.key-value.debian.tests.control
      push:
        - meta_scope: meta.mapping.debian.tests.control
        - meta_content_scope: meta.mapping.value.debian.tests.control
        - match: ^(?=\S)
          pop: true
        - include: features
        - match: ','
          scope: punctuation.separator.sequence.debian.tests.control
    # Depends field — package names with special @ expansions
    - match: ^(Depends)(:)
      captures:
        1: meta.mapping.key.debian keyword.control.debian.tests.control
        2: meta.mapping.key.debian punctuation.separator.mapping.key-value.debian.tests.control
      push:
        - meta_scope: meta.mapping.debian.tests.control
        - meta_content_scope: meta.mapping.value.debian.tests.control
        - match: ^(?=\S)
          pop: true
        - match: '(@)(builddeps|recommends)(@)'
          captures:
            1: punctuation.definition.variable.debian.tests.control
            2: variable.language.debian.tests.control
            3: punctuation.definition.variable.debian.tests.control
        - match: '@'
          scope: variable.language.debian.tests.control
        - include: debian-common.sublime-syntax#semver-flag
        - match: \,|\|
          scope: punctuation.separator.sequence.debian.tests.control
        - include: debian-common.sublime-syntax#package-name
    # Architecture field
    - match: ^(Architecture)(:)
      captures:
        1: meta.mapping.key.debian keyword.control.debian.tests.control
        2: meta.mapping.key.debian punctuation.separator.mapping.key-value.debian.tests.control
      push:
        - meta_scope: meta.mapping.debian.tests.control
        - meta_content_scope: meta.mapping.value.debian.tests.control
        - match: ^(?=\S)
          pop: true
        - include: debian-common.sublime-syntax#architectures
    # Other fields — Tests-Directory, Classes
    - match: ^(Tests-Directory|Classes)(:)
      captures:
        1: meta.mapping.key.debian keyword.control.debian.tests.control
        2: meta.mapping.key.debian punctuation.separator.mapping.key-value.debian.tests.control
      push:
        - meta_scope: meta.mapping.debian.tests.control
        - meta_content_scope: meta.mapping.value.debian.tests.control
        - match: ^(?=\S)
          pop: true
        - match: ','
          scope: punctuation.separator.sequence.debian.tests.control
    # Catch-all for unknown fields
    - include: debian-common.sublime-syntax#deb822-unknown-field

  features:
    - match: (test-name)(=)(\S+)
      captures:
        1: support.constant.feature.debian.tests.control
        2: punctuation.separator.mapping.key-value.debian.tests.control
        3: string.unquoted.debian.tests.control
