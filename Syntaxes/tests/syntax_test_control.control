#                 ^ keyword.operator.comparison.debian.control
#                   ^^^^^^^^^^^^^^^^^ variable.language.debian
#                   ^^ punctuation.definition.variable.begin.debian.control
#                                    ^ punctuation.section.group.end.debian.control

# Test Depends continuation with substvars (assertions on last line only)
Depends: libfoo1 (= ${binary:Version}),
         libbar-dev (>= ${binary:Version}),
         libfoo1 (>= ${source:Version}),
         ${shlibs:Depends},
         ${perl:Depends},
         ${gir:Depends},
         ${misc:Depends}
#        ^^^^^^^^^^^^^^^ variable.language.debian
#        ^^ punctuation.definition.variable.begin.debian.control
#                      ^ punctuation.definition.variable.end.debian.control
Recommends: libfoo-doc [linux-amd64]
