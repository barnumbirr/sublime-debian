# Test Depends header keyword
Depends: adduser
#^^^^^^ meta.mapping.key.debian keyword.control.debian.control
#       ^^^^^^^^ meta.mapping.value.debian.control

# Test Depends continuation values with version constraints and alternatives
Depends: adduser,
         apache2 | httpd,
         apache2-utils,
         backuppc-rsync (>= 3.1.3),
         perl (>> 5.28),
         rrdtool (<= 1.8.0),
         libfoo (<< 2.0),
         bzip2,
         default-mta | exim4 | mail-transport-agent,
         iputils-ping | inetutils-ping,
         libarchive-zip-perl,
         libbackuppc-xs-perl (>= 0.62),
         libcgi-pm-perl,
         libdigest-md5-perl,
         libfile-listing-perl,
         libio-compress-perl | libcompress-zlib-perl,
         libtime-parsedate-perl,
         lsb-base,
         ucf,
         ${misc:Depends},
         ${perl:Depends},
         ${shlibs:Depends}
#        ^^^^^^^^^^^^^^^^^ variable.language.debian

# Test Depends with version constraints on a single line
Depends: backuppc-rsync (>= 3.1.3)
