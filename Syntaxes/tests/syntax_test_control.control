Recommends: libio-dirent-perl,
            openssh-client | ssh-client,
            rrdtool,
            samba-common-bin,
            smbclient
Suggests: certbot | acme-tiny | acmetool | dehydrated | lacme | lecm | lego,
          libscgi-perl,
          par2,
          rsync,
          w3m | www-browser

# Test Description header
Description: high-performance, enterprise-grade system for backing up PCs
#^^^^^^^^^^ meta.mapping.key.debian keyword.control.debian.control
#          ^ punctuation.separator.mapping.key-value.debian.control
#           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ meta.description.synopsis.debian.control

# Test Description body with paragraph markers
Description: test paragraph separator
 First paragraph text.
 Second paragraph text.
 .
 Third paragraph text.
 .
#^ punctuation.separator.paragraph.debian.control

Package: libfoo-dev
Architecture: any
Multi-Arch: same

# Test Depends with substvar on single line
Depends: libfoo1 (= ${binary:Version})
