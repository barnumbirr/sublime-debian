# Test Build-Depends header keyword
Build-Depends: debhelper-compat (= 13)
#^^^^^^^^^^^^ meta.mapping.key.debian keyword.control.debian.control
#            ^ punctuation.separator.mapping.key-value.debian.control
#              ^^^^^^^^^^^^^^^ support.module.debian

# Test Build-Depends continuation values (assertions on last line only)
Build-Depends: debhelper-compat (= 13),
               iputils-ping | inetutils-ping,
               libbackuppc-xs-perl (>= 0.62),
               libcgi-pm-perl,
               libfile-listing-perl,
               par2,
               patch,
               perl,
               rrdtool
#              ^^^^^^ support.module.debian
Architecture: any
#^^^^^^^^^^^ meta.mapping.key.debian keyword.control.debian.control
#           ^ punctuation.separator.mapping.key-value.debian.control
#            ^^^^ meta.mapping.value.debian.control
#             ^^^ constant.other.architecture.debian
Rules-Requires-Root: binary-targets
#^^^^^^^^^^^^^^^^^^ meta.mapping.key.debian keyword.control.debian.control
#                  ^ punctuation.separator.mapping.key-value.debian.control
#                   ^^^^^^^^^^^^^^^ meta.mapping.value.debian.control
#                    ^^^^^^^^^^^^^^ support.constant.debian.control
Standards-Version: 4.5.1
Homepage: https://backuppc.github.io/backuppc/
#^^^^^^^ meta.mapping.key.debian keyword.control.debian.control
#       ^ punctuation.separator.mapping.key-value.debian.control
#        ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ meta.mapping.value.debian.control
#         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ markup.underline.link.debian
Vcs-Git: https://salsa.debian.org/debian/backuppc.git
Vcs-Browser: https://salsa.debian.org/debian/backuppc

Package: backuppc
Architecture: amd64 arm64 i386
#             ^^^^^ constant.other.architecture.debian
#                   ^^^^^ constant.other.architecture.debian
#                         ^^^^ constant.other.architecture.debian
Multi-Arch: same
#^^^^^^^^^ meta.mapping.key.debian keyword.control.debian.control
#         ^ punctuation.separator.mapping.key-value.debian.control
#          ^^^^^ meta.mapping.value.debian.control
#           ^^^^ support.constant.multi-arch.debian.control
Essential: yes
#        ^ punctuation.separator.mapping.key-value.debian.control
#         ^^^^ meta.mapping.value.debian.control
#          ^^^ constant.language.boolean.true.debian.control
Package-Type: udeb
#           ^ punctuation.separator.mapping.key-value.debian.control
#             ^^^^ storage.type.debian.control
Installed-Size: 1024
#               ^^^^ constant.numeric.integer.decimal.debian.control
Section: non-free/games
#        ^^^^^^^^^^^^^^ support.constant.section.debian.control
#                ^ punctuation.separator.path.debian.control
Pre-Depends: ${misc:Pre-Depends}
