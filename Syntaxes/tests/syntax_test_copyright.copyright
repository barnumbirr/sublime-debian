# SYNTAX TEST "Packages/Debian Syntax/Syntaxes/debian-copyright.sublime-syntax"

Format: https://www.debian.org/doc/packaging-manuals/copyright-format/1.0/
#^^^^^ meta.mapping.key.debian keyword.control.debian.copyright
#      ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ meta.mapping.value.debian.copyright
#       ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ markup.underline.link.debian
Upstream-Name: backuppc
Source: http://backuppc.sourceforge.net/
#^^^^^ meta.mapping.key.debian keyword.control.debian.copyright
#      ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ meta.mapping.value.debian.copyright
#       ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^ markup.underline.link.debian

