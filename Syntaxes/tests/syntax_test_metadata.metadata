# Nested mapping (Reference block)
Reference:
# <- meta.mapping.key.debian keyword.control.debian.metadata
#^^^^^^^^ meta.mapping.key.debian keyword.control.debian.metadata
#        ^ punctuation.separator.mapping.key-value.debian.metadata
 Author: John Doe
#^^^^^^ variable.parameter.debian.metadata
#      ^ punctuation.separator.mapping.key-value.debian.metadata
 Title: Some Paper
#^^^^^ variable.parameter.debian.metadata
#     ^ punctuation.separator.mapping.key-value.debian.metadata
 URL: https://doi.org/10.1234/example
#^^^ variable.parameter.debian.metadata
#   ^ punctuation.separator.mapping.key-value.debian.metadata
#     ^^^^^ markup.underline.link.scheme.debian

# Unknown field (catch-all)
X-Custom-Field: some value
