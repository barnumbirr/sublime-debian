# SYNTAX TEST "Packages/Debian Syntax/Syntaxes/debian-triggers.sublime-syntax"

# dpkg triggers for backuppc
# <- punctuation.definition.comment.debian
#^^^^^^^^^^^^^^^^^^^^^^^^^^^^ comment.line.debian

interest /usr/share/icons/hicolor
#^^^^^^^ meta.mapping.key.debian keyword.control.debian.triggers
#        ^^^^^^^^^^^^^^^^^^^^^^^^ meta.mapping.value.debian.triggers
#        ^^^^^^^^^^^^^^^^^^^^^^^^ string.unquoted.path.debian.triggers

interest-await /usr/share/applications
#^^^^^^^ keyword.control.debian.triggers
#       ^^^^^^ storage.modifier.debian.triggers
#              ^^^^^^^^^^^^^^^^^^^^^^^ meta.mapping.value.debian.triggers
#              ^^^^^^^^^^^^^^^^^^^^^^^ string.unquoted.path.debian.triggers

interest-noawait /usr/share/mime/packages
#^^^^^^^ keyword.control.debian.triggers
#       ^^^^^^^^ storage.modifier.debian.triggers
#                ^^^^^^^^^^^^^^^^^^^^^^^^ meta.mapping.value.debian.triggers
#                ^^^^^^^^^^^^^^^^^^^^^^^^ string.unquoted.path.debian.triggers

activate ldconfig
# <- keyword.control.debian.triggers
#^^^^^^^ meta.mapping.key.debian keyword.control.debian.triggers
#        ^^^^^^^^ meta.mapping.value.debian.triggers
