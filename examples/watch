version=4
# Example watch file for uscan
opts=dversionmangle=s/\+dfsg//,filenamemangle=s/.*\///,pgpmode=auto \
  https://github.com/backuppc/backuppc/tags .*/v?([\d.]+)\.tar\.gz

opts=component=libbackuppc-xs,compression=xz,repack,repacksuffix=+dfsg \
  https://github.com/backuppc/backuppc-xs/tags .*/v?([\d.]+)\.tar\.gz

opts=uversionmangle=s/_/./g,downloadurlmangle=s/tag/archive/ \
  https://github.com/backuppc/backuppc/releases .*/v([\d.]+)\.tar\.gz

opts=decompress,bare,mode=git \
  https://salsa.debian.org/debian/backuppc.git HEAD

opts=pretty=oneline,date=short,searchmode=plain,gitmode=full \
  https://salsa.debian.org/debian/backuppc.git refs/tags/v([\d.]+)

opts=ctype=nodejs,hrefdecode=percent,user-agent=uscan \
  https://registry.npmjs.org/backuppc-ui .*/backuppc-ui-([\d.]+)\.tgz

opts=gitexport=all,gitmodules \
  https://salsa.debian.org/debian/backuppc.git refs/tags/v([\d.]+)

opts=pagemangle=s/[^.]*\.(.*)/\1/,pgpsigurlmangle=s/$/.asc/,unzipopt=-j \
  https://example.com/releases/ .*/backuppc-([\d.]+)\.tar\.gz

opts=oversionmangle=s/-/./g,dirversionmangle=s/[^0-9]//g \
  https://example.com/archive/ .*/v([\d.]+)/

opts=template=watch.in,update-script=debian/update-watch \
  https://example.com/releases/ .*/backuppc-([\d.]+)\.tar\.gz

opts=version-constraint=">= 4.0",version-schema=basic,version-separator=- \
  https://example.com/releases/ .*/backuppc-([\d.]+)\.tar\.gz

opts=source=https://example.com,matching-pattern=backuppc-(.*).tar.gz \
  https://example.com/releases/ .*/backuppc-([\d.]+)\.tar\.gz

# Watch file version 5 (RFC 822 paragraph format)
Version: 5

# Simple HTTP source
Source: https://github.com/backuppc/backuppc/tags
Matching-Pattern: .*/v?@ANY_VERSION@@ARCHIVE_EXT@
Dversion-Mangle: s/\+dfsg//
Filename-Mangle: s/.*\///
Pgp-Mode: auto
Compression: xz

# Using a template
Template: GitHub
Owner: backuppc
Project: backuppc
Version-Mangle: auto

# Multiple upstream tarballs
Component: libbackuppc-xs
Source: https://github.com/backuppc/backuppc-xs/tags
Matching-Pattern: .*/v?@ANY_VERSION@@ARCHIVE_EXT@
Repacksuffix: +dfsg
Repack: yes
Version-Constraint: same

# Git mode
Source: https://salsa.debian.org/debian/backuppc.git
Matching-Pattern: refs/tags/@ANY_VERSION@
Mode: git
Git-Mode: shallow
Git-Pretty: oneline
Git-Date: short
Git-Export: all
Git-Modules: yes

# Node.js with checksum versioning
Version-Schema: checksum
Search-Mode: plain
Source: https://registry.npmjs.org/mongodb
Matching-Pattern: https://registry.npmjs.org/mongodb/-/mongodb-@ANY_VERSION@@ARCHIVE_EXT@

# Numeric and boolean options
Compression-Level: 9
Bare: yes
Decompress: yes
Release-Only: yes

# Custom user agent and download options
User-Agent: uscan
Unzip-Opt: -j
Ctype: sha256
Hrefdecode: perl
Git-Export: all

# Temporarily disabled tracking
Untrackable: upstream site is down, will re-enable later
Source: https://keeped-site-to-be-used-later/
Matching-Pattern: .*@ANY_VERSION@@ARCHIVE_EXT@
